{
  "extends": "./tsconfig.json",
  "compilerOptions": {
      "allowImportingTsExtensions": false,
    "noEmit": false,
    "outDir": "electron-dist",
    "esModuleInterop": true,
    "module": "esnext",
    "target": "esnext",
    "types": ["node", "electron"],
    "moduleResolution": "node"
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules/bun-types/*", "src/**/*", "**/*.test.ts"]
}
