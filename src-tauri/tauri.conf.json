{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mirror",
  "version": "0.2.1",
  "identifier": "com.mirror.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mirror",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icon32.png",
      "../assets/icon128.png",
      "../assets/icon256.png",
      "../assets/icon512.png",
      "../assets/icon1024.png",
      "../assets/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
