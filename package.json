{
  "name": "mirror",
  "version": "0.2.2",
  "description": "AI-assisted translation editor",
  "author": {
    "name": "Simone Sturniolo",
    "email": "simonesturniolo@gmail.com"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri:icons": "tauri icon assets/icon1024.png",
    "tauri:dev": "tauri dev",
    "tauri:build": "APPIMAGE_EXTRACT_AND_RUN=1 tauri build",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "typecheck": "tsc --noEmit",
    "generate-icons": "bun run scripts/generate_icons.ts",
    "postversion": "bun run scripts/sync-cargo-version.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@types/bun": "latest",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.2.0",
    "png-to-ico": "^3.0.1",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.11.1",
    "@blueprintjs/icons": "^6.8.0",
    "@tauri-apps/api": "^2.11.0",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "franc": "^6.2.0",
    "i18next": "^25.10.10",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.2",
    "yaml": "^2.8.3"
  }
